# Discord configuration
DISCORD_TOKEN=your-discord-bot-token
CLIENT_ID=your-bot-application-client-id
GUILD_ID=your-discord-guild-id

# Alert channel where embeds are posted
ALERT_CHANNEL_ID=123456789012345678

# Optional: comma-separated list of channels to monitor for Policy IDs.
# If left empty, the bot listens on every channel it can read.
MONITORED_CHANNEL_IDS=

# Optional: role ID pinged on first-seen Policy IDs (Alpha alerts)
ALPHA_ROLE_ID=

# Blockfrost
# Get one at https://blockfrost.io – choose the "mainnet" project
BLOCKFROST_API_KEY=mainnetXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BLOCKFROST_NETWORK=mainnet

# DexHunter – partner API key is optional, public endpoints still work without it
DEXHUNTER_API_KEY=
DEXHUNTER_PARTNER_ID=

# Optional Koios fallback
KOIOS_BASE_URL=https://api.koios.rest/api/v1
KOIOS_API_KEY=

# Storage
# Path to the SQLite database file (directory will be created if missing)
DATABASE_PATH=./data/lumpbot.sqlite

# Optional webhook forwarded every alert (for external integrations)
EXTERNAL_WEBHOOK_URL=

# Logging
LOG_LEVEL=info
